---
import CheckIcon from "./icons/CheckIcon.astro";
import DownloadIcon from "./icons/DownloadIcon.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import ExternalLinkIcon from "./icons/ExternalLinkIcon.astro";

const requirements = [
  "macOS 14.0+",
  "Apple Silicon & Intel",
  "Free and open source",
  "Optional: your own GCP or Deepgram keys",
];
---

<section id="download" class="download section">
  <div class="container">
    <div class="download__panel card-glass">
      <div class="download__copy">
        <span class="download__label">Download</span>
        <h2 class="download__title">
          Ready to make dictation part of your
          <span class="text-gradient">everyday workflow?</span>
        </h2>
        <p class="download__description">
          Pick the transcription engine that fits the moment, let Gemini polish
          the result, and start writing with your voice from anywhere on macOS.
        </p>

        <ul class="download__requirements">
          {
            requirements.map((item) => (
              <li>
                <span class="download__check">
                  <CheckIcon size={14} />
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="download__actions">
        <a
          href="https://github.com/StevenACZ/SapoWhisper/releases/latest"
          target="_blank"
          rel="noopener noreferrer"
          class="download__button"
        >
          <span class="download__button-icon">
            <DownloadIcon size={20} />
          </span>
          <span class="download__button-text">
            <span class="download__button-label">Download latest release</span>
            <strong>macOS app</strong>
          </span>
        </a>

        <a
          href="https://github.com/StevenACZ/SapoWhisper"
          target="_blank"
          rel="noopener noreferrer"
          class="download__secondary"
        >
          <GitHubIcon size={18} />
          <span>View source on GitHub</span>
        </a>

        <a
          href="https://github.com/StevenACZ/SapoWhisper/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="download__secondary"
        >
          <ExternalLinkIcon size={18} />
          <span>Report an issue</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/variables" as *;

  .download {
    position: relative;

    &__panel {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
      gap: $spacing-2xl;
      padding: $spacing-3xl;
      border-radius: 32px;
      background: linear-gradient(
        135deg,
        rgba(16, 185, 129, 0.08),
        rgba(255, 255, 255, 0.02)
      );
    }

    &__label {
      display: inline-block;
      margin-bottom: $spacing-md;
      color: $primary-300;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
      font-weight: 700;
    }

    &__title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: $spacing-lg;
    }

    &__description {
      color: $neutral-400;
      font-size: 1.05rem;
      line-height: 1.7;
      max-width: 640px;
    }

    &__requirements {
      display: grid;
      gap: 0.65rem;
      margin-top: $spacing-xl;
      list-style: none;

      li {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        color: $neutral-200;
        font-size: 0.95rem;
      }
    }

    &__check {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: rgba(16, 185, 129, 0.14);
      color: $primary-300;
      flex-shrink: 0;
    }

    &__actions {
      display: grid;
      gap: 0.8rem;
      align-content: center;
    }

    &__button {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 0.85rem;
      padding: 1rem 1.2rem;
      border-radius: $radius-xl;
      background: linear-gradient(135deg, $primary-500, $primary-700);
      color: white;
      box-shadow: $shadow-lg, $shadow-glow-sm;
      transition: transform $transition-base;

      &:hover {
        transform: translateY(-2px);
      }
    }

    &__button-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.18);
    }

    &__button-text {
      display: grid;
      gap: 0.2rem;
    }

    &__button-label {
      font-size: 0.85rem;
      opacity: 0.92;
    }

    &__button strong {
      font-size: 1.1rem;
    }

    &__secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.85rem 1rem;
      border-radius: $radius-xl;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      color: $neutral-200;
      font-weight: 500;
      transition:
        transform $transition-base,
        border-color $transition-base,
        background $transition-base;

      &:hover {
        border-color: rgba(16, 185, 129, 0.18);
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-2px);
      }
    }
  }

  @media (max-width: 900px) {
    .download__panel {
      grid-template-columns: 1fr;
      padding: $spacing-2xl;
    }
  }
</style>
