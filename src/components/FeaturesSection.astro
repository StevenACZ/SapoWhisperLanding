---
import CommandIcon from "./icons/CommandIcon.astro";
import ClipboardIcon from "./icons/ClipboardIcon.astro";
import MicIcon from "./icons/MicIcon.astro";
import LanguagesIcon from "./icons/LanguagesIcon.astro";

const features = [
  {
    icon: CommandIcon,
    tag: "Trigger anywhere",
    title: "Global hotkey workflow",
    description:
      "Press ⌥ + Space (or your own shortcut) from any app — the recording overlay appears without stealing focus.",
  },
  {
    icon: ClipboardIcon,
    tag: "Output",
    title: "Auto-copy and auto-paste",
    description:
      "The polished transcript lands in your clipboard and drops directly where your cursor is, so dictation feels like typing.",
  },
  {
    icon: MicIcon,
    tag: "Audio control",
    title: "Built for daily mic use",
    description:
      "Preferred microphone sync, mic test, gain controls, audio cues and auto-ducking that lowers system volume while you talk.",
  },
  {
    icon: LanguagesIcon,
    tag: "Bilingual UI",
    title: "Spanish and English",
    description:
      "Swap the interface and the transcription language between Spanish, English or Auto — recognise both without restarting.",
  },
];
---

<section id="features" class="features section">
  <div class="container">
    <div class="features__header">
      <span class="features__label">Power features</span>
      <h2 class="features__title">
        Built around the
        <span class="text-gradient">real dictation workflow</span>
      </h2>
      <p class="features__description">
        Engines and AI handle the transcript. These are the everyday touches
        that make SapoWhisper feel like part of your Mac, not a separate tool.
      </p>
    </div>

    <div class="features__grid">
      {
        features.map((feature) => (
          <article class="feature-card">
            <div class="feature-card__icon">
              <feature.icon size={22} />
            </div>
            <span class="feature-card__tag">{feature.tag}</span>
            <h3 class="feature-card__title">{feature.title}</h3>
            <p class="feature-card__description">{feature.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/variables" as *;

  .features {
    position: relative;

    &__header {
      max-width: 740px;
      margin: 0 auto $spacing-3xl;
      text-align: center;
    }

    &__label {
      display: inline-block;
      margin-bottom: $spacing-md;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: $primary-300;
    }

    &__title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: $spacing-md;
    }

    &__description {
      color: $neutral-400;
      font-size: 1.05rem;
      line-height: 1.7;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: $spacing-lg;
    }
  }

  .feature-card {
    display: grid;
    gap: 0.6rem;
    padding: $spacing-xl;
    border-radius: $radius-2xl;
    background: $bg-dark-secondary;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all $transition-base;

    &:hover {
      border-color: rgba(16, 185, 129, 0.22);
      transform: translateY(-4px);
      box-shadow: $shadow-lg;
    }

    &__icon {
      width: 44px;
      height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.18);
      color: $primary-300;
      margin-bottom: 0.2rem;
    }

    &__tag {
      color: $neutral-500;
      font-size: 0.74rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }

    &__title {
      font-size: 1.05rem;
      line-height: 1.3;
      color: $neutral-50;
    }

    &__description {
      color: $neutral-400;
      line-height: 1.65;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 1100px) {
    .features__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
