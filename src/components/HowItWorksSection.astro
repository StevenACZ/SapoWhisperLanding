---
import CommandIcon from "./icons/CommandIcon.astro";
import MicIcon from "./icons/MicIcon.astro";
import WaveformIcon from "./icons/WaveformIcon.astro";
import SparklesIcon from "./icons/SparklesIcon.astro";
import ClipboardIcon from "./icons/ClipboardIcon.astro";

const steps = [
  {
    number: "01",
    icon: CommandIcon,
    eyebrow: "Trigger",
    title: "Press your shortcut",
    description:
      "⌥ + Space (or your own) brings up the recording overlay from any app.",
  },
  {
    number: "02",
    icon: MicIcon,
    eyebrow: "Capture",
    title: "Speak naturally",
    description:
      "Preferred mic, gain control, auto-ducking and pause / resume when you need it.",
  },
  {
    number: "03",
    icon: WaveformIcon,
    eyebrow: "Transcribe",
    title: "Pick your engine",
    description:
      "Apple, WhisperKit, Google Cloud Chirp 3 or Deepgram Nova-3 / Flux Live.",
  },
  {
    number: "04",
    icon: SparklesIcon,
    eyebrow: "Refine",
    title: "AI polishes the text",
    description:
      "Gemini 3.1 Flash-Lite on Vertex AI cleans up the transcript without inventing details.",
  },
  {
    number: "05",
    icon: ClipboardIcon,
    eyebrow: "Output",
    title: "Paste and keep history",
    description:
      "Auto-paste lands the result where your cursor is. Everything stays searchable.",
  },
];
---

<section id="how-it-works" class="workflow section">
  <div class="container">
    <div class="workflow__header">
      <span class="workflow__label">Workflow</span>
      <h2 class="workflow__title">
        Five stages from voice
        <span class="text-gradient">to clean text</span>
      </h2>
      <p class="workflow__description">
        Trigger, capture, transcribe, refine, paste. SapoWhisper hides the
        complexity so you can stay in your editor.
      </p>
    </div>

    <ol class="stepper" data-stepper>
      {
        steps.map((step, index) => (
          <li
            class:list={["stepper__item", { "is-active": index === 0 }]}
            data-stepper-item
          >
            <div class="stepper__dot">
              <span class="stepper__dot-number">{step.number}</span>
              <span class="stepper__dot-icon">
                <step.icon size={18} />
              </span>
            </div>
            <div class="stepper__body">
              <span class="stepper__eyebrow">{step.eyebrow}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
            {index < steps.length - 1 && (
              <span class="stepper__connector" aria-hidden="true" />
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>

<script>
  const stepper = document.querySelector<HTMLElement>("[data-stepper]");
  const items = document.querySelectorAll<HTMLElement>("[data-stepper-item]");

  if (stepper && items.length > 0) {
    const total = items.length;
    let current = 0;
    const update = (index: number) => {
      items.forEach((el, i) => {
        el.classList.toggle("is-active", i === index);
        el.classList.toggle("is-completed", i < index);
      });
    };

    const advance = () => {
      current = (current + 1) % total;
      update(current);
    };

    // Pause auto-advance when the user prefers reduced motion or hovers.
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let interval: ReturnType<typeof setInterval> | null = null;
    if (!reduced) {
      interval = setInterval(advance, 2600);
      stepper.addEventListener("mouseenter", () => {
        if (interval) clearInterval(interval);
      });
      stepper.addEventListener("mouseleave", () => {
        interval = setInterval(advance, 2600);
      });
    }

    items.forEach((el, i) =>
      el.addEventListener("click", () => {
        current = i;
        update(current);
      }),
    );
  }
</script>

<style lang="scss">
  @use "../styles/variables" as *;

  .workflow {
    position: relative;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.015),
      transparent 40%
    );

    &__header {
      max-width: 760px;
      margin: 0 auto $spacing-3xl;
      text-align: center;
    }

    &__label {
      display: inline-block;
      margin-bottom: $spacing-md;
      color: $primary-300;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.85rem;
      font-weight: 700;
    }

    &__title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: $spacing-md;
    }

    &__description {
      color: $neutral-400;
      font-size: 1.05rem;
      line-height: 1.7;
    }
  }

  .stepper {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: $spacing-md;
    list-style: none;
    padding: 0;

    &__item {
      position: relative;
      display: grid;
      gap: 0.85rem;
      padding: 0.4rem 0.2rem 1rem;
      text-align: center;
      cursor: pointer;
    }

    &__dot {
      position: relative;
      width: 72px;
      height: 72px;
      margin: 0 auto;
      border-radius: 999px;
      background: $bg-dark-secondary;
      border: 2px solid rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all $transition-base;
      z-index: 1;

      .stepper__item.is-active & {
        border-color: $primary-500;
        background: rgba(16, 185, 129, 0.12);
        box-shadow:
          0 0 0 6px rgba(16, 185, 129, 0.1),
          0 0 28px rgba(16, 185, 129, 0.3);
      }

      .stepper__item.is-completed & {
        border-color: rgba(16, 185, 129, 0.5);
        background: rgba(16, 185, 129, 0.06);
      }
    }

    &__connector {
      position: absolute;
      top: calc(0.4rem + 36px - 1px);
      left: calc(50% + 40px);
      width: calc(100% - 80px + #{$spacing-md});
      height: 2px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      pointer-events: none;
      transition:
        background $transition-base,
        box-shadow $transition-base;

      .stepper__item.is-completed & {
        background: linear-gradient(90deg, $primary-500, $primary-400);
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.45);
      }
    }

    &__dot-number {
      color: $neutral-500;
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      transition: opacity $transition-base;

      .stepper__item.is-active & {
        opacity: 0;
      }
    }

    &__dot-icon {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: $primary-300;
      opacity: 0;
      transition: opacity $transition-base;

      .stepper__item.is-active & {
        opacity: 1;
      }
    }

    &__body {
      display: grid;
      gap: 0.35rem;
      padding: 0 0.25rem;

      h3 {
        font-size: 0.98rem;
        line-height: 1.3;
        color: $neutral-100;
      }

      p {
        color: $neutral-400;
        font-size: 0.85rem;
        line-height: 1.55;
      }
    }

    &__eyebrow {
      color: $neutral-500;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 700;

      .stepper__item.is-active & {
        color: $primary-300;
      }
    }
  }

  @media (max-width: 900px) {
    .stepper {
      grid-template-columns: 1fr;
      gap: $spacing-lg;

      &__item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: $spacing-md;
        text-align: left;
        padding: 0;
      }

      &__dot {
        width: 56px;
        height: 56px;
        margin: 0;
      }

      &__connector {
        display: none;
      }

      &__body {
        padding: 0;

        h3 {
          font-size: 1rem;
        }
      }
    }
  }
</style>
