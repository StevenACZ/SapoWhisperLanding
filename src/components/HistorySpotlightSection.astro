---
import SearchIcon from "./icons/SearchIcon.astro";
import HeadphonesIcon from "./icons/HeadphonesIcon.astro";
import RefreshIcon from "./icons/RefreshIcon.astro";
import PinIcon from "./icons/PinIcon.astro";
import DownloadIcon from "./icons/DownloadIcon.astro";
import WaveformIcon from "./icons/WaveformIcon.astro";
import SparklesIcon from "./icons/SparklesIcon.astro";

const points = [
  {
    icon: SearchIcon,
    title: "Search what you already said",
    description:
      "Find older transcripts quickly instead of dictating the same thing twice.",
  },
  {
    icon: HeadphonesIcon,
    title: "Replay the original audio",
    description:
      "Listen back before sharing, editing, or comparing transcription quality.",
  },
  {
    icon: RefreshIcon,
    title: "Try another engine later",
    description:
      "Re-process the same recording when accuracy matters more than speed.",
  },
];

const entries = [
  {
    title: "Follow-up for design review",
    engine: "Deepgram",
    preview: "Can you send the latest mockups before lunch?",
    active: false,
  },
  {
    title: "Quick support reply",
    engine: "WhisperKit",
    preview: "I tested the issue locally and can reproduce it on macOS 14.",
    active: true,
  },
  {
    title: "Meeting takeaway",
    engine: "Google Cloud",
    preview:
      "Let's keep the shortcut workflow and make History easier to scan.",
    active: false,
  },
];

const chips = [
  { icon: HeadphonesIcon, label: "Audio playback" },
  { icon: RefreshIcon, label: "Re-transcribe" },
  { icon: DownloadIcon, label: "Download audio" },
  { icon: SparklesIcon, label: "Re-polish with AI" },
];
---

<section id="history" class="history section">
  <div class="container history__container">
    <div class="history__content">
      <span class="history__label">History</span>
      <h2 class="history__title">
        More than one-shot
        <span class="text-gradient">transcription</span>
      </h2>
      <p class="history__description">
        SapoWhisper keeps working after the paste. Search past transcripts,
        replay the original audio, pin important entries, and run the same clip
        through another engine when you want a better result.
      </p>

      <div class="history__points">
        {
          points.map((point) => (
            <div class="history__point">
              <div class="history__point-icon">
                <point.icon size={18} />
              </div>
              <div>
                <h3>{point.title}</h3>
                <p>{point.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="history__visual card-glass">
      <div class="history__window">
        <div class="history__window-bar">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="history__workspace">
          <aside class="history__sidebar">
            <div class="history__search">
              <SearchIcon size={14} />
              Search transcripts...
            </div>
            {
              entries.map((entry) => (
                <div
                  class:list={[
                    "history__entry",
                    { "is-active": entry.active },
                  ]}
                >
                  <div class="history__entry-top">
                    <strong>{entry.title}</strong>
                    <span>{entry.engine}</span>
                  </div>
                  <p>{entry.preview}</p>
                </div>
              ))
            }
          </aside>

          <div class="history__detail">
            <div class="history__badge">
              <PinIcon size={12} />
              Pinned transcript
            </div>
            <h3>Review, replay, and refine</h3>
            <p>
              Keep the original audio, compare engines, and export the result
              you actually want to keep.
            </p>

            <div class="history__chips">
              {
                chips.map((chip) => (
                  <span>
                    <chip.icon size={14} />
                    {chip.label}
                  </span>
                ))
              }
            </div>

            <div class="history__mini-player">
              <div class="history__mini-player-head">
                <WaveformIcon size={16} />
                <span>Recorded from preferred microphone</span>
              </div>
              <div class="history__mini-player-wave">
                {Array.from({ length: 16 }).map(() => <span />)}
              </div>
              <div class="history__mini-player-meta">
                <strong>00:18 / 00:34</strong>
                <small>Deepgram Nova-3 · AI polished</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/variables" as *;

  .history {
    position: relative;
    overflow: hidden;

    &__container {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      gap: $spacing-3xl;
      align-items: center;
    }

    &__label {
      display: inline-block;
      margin-bottom: $spacing-md;
      color: $primary-300;
      font-size: 0.875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    &__title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: $spacing-lg;
    }

    &__description {
      color: $neutral-400;
      font-size: 1.0625rem;
      line-height: 1.7;
      margin-bottom: $spacing-xl;
    }

    &__points {
      display: grid;
      gap: $spacing-lg;
    }

    &__point {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: $spacing-md;
      align-items: start;

      h3 {
        font-size: 1rem;
        margin-bottom: 0.3rem;
      }

      p {
        color: $neutral-400;
        font-size: 0.92rem;
        line-height: 1.6;
      }
    }

    &__point-icon {
      width: 40px;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: $radius-lg;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: $primary-300;
    }

    &__visual {
      padding: $spacing-lg;
      border-radius: 28px;
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.02)
      );
    }

    &__window {
      border-radius: 22px;
      overflow: hidden;
      background: #0e1014;
      border: 1px solid rgba(255, 255, 255, 0.06);
      box-shadow: $shadow-xl;
    }

    &__window-bar {
      display: flex;
      gap: 0.5rem;
      padding: 0.9rem 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.02);

      span {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.18);
      }
    }

    &__workspace {
      display: grid;
      grid-template-columns: 0.88fr 1.12fr;
      min-height: 440px;
    }

    &__sidebar {
      padding: 0.9rem;
      border-right: 1px solid rgba(255, 255, 255, 0.05);
      background: rgba(255, 255, 255, 0.015);
    }

    &__search {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      width: 100%;
      margin-bottom: 1rem;
      padding: 0.75rem 0.9rem;
      border-radius: $radius-lg;
      background: rgba(255, 255, 255, 0.04);
      color: $neutral-500;
      font-size: 0.88rem;
    }

    &__entry {
      padding: 0.85rem;
      border-radius: $radius-lg;
      margin-bottom: 0.55rem;
      border: 1px solid transparent;

      &.is-active {
        background: rgba(16, 185, 129, 0.08);
        border-color: rgba(16, 185, 129, 0.18);
      }

      p {
        color: $neutral-400;
        font-size: 0.86rem;
        line-height: 1.5;
      }
    }

    &__entry-top {
      display: flex;
      justify-content: space-between;
      gap: 0.6rem;
      margin-bottom: 0.3rem;

      strong {
        font-size: 0.92rem;
        color: $neutral-100;
      }

      span {
        font-size: 0.72rem;
        color: $primary-300;
        font-weight: 600;
      }
    }

    &__detail {
      padding: 1.4rem;

      h3 {
        font-size: 1.4rem;
        margin-bottom: 0.6rem;
      }

      p {
        color: $neutral-400;
        line-height: 1.7;
      }
    }

    &__badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.75rem;
      margin-bottom: 0.85rem;
      border-radius: 999px;
      background: rgba(16, 185, 129, 0.12);
      color: $primary-200;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    &__chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 1.2rem 0 1.4rem;

      span {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.07);
        color: $neutral-300;
        font-size: 0.82rem;
      }
    }

    &__mini-player {
      padding: 0.9rem 1rem;
      border-radius: $radius-xl;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    &__mini-player-head {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      margin-bottom: 0.65rem;
      color: $neutral-300;
      font-size: 0.82rem;
    }

    &__mini-player-wave {
      display: flex;
      align-items: end;
      gap: 0.25rem;
      height: 40px;
      margin-bottom: 0.75rem;

      span {
        flex: 1;
        border-radius: 999px;
        background: linear-gradient(
          180deg,
          rgba(52, 211, 153, 0.9),
          rgba(59, 130, 246, 0.45)
        );
        animation: history-wave 1.2s ease-in-out infinite;

        &:nth-child(odd) {
          animation-delay: 0.2s;
        }

        &:nth-child(3n) {
          animation-delay: 0.35s;
        }
      }
    }

    &__mini-player-meta {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;

      strong {
        font-size: 0.88rem;
        color: $neutral-100;
      }

      small {
        color: $primary-300;
        font-size: 0.78rem;
        font-weight: 500;
      }
    }
  }

  @keyframes history-wave {
    0%,
    100% {
      height: 20%;
    }
    50% {
      height: 100%;
    }
  }

  @media (max-width: 1024px) {
    .history__container {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .history__workspace {
      grid-template-columns: 1fr;
    }

    .history__sidebar {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
  }
</style>
